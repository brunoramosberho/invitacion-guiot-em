{
  "rewrites": [
    { "source": "/api/og/s/:token", "destination": "/api/og?t=:token" },
    { "source": "/api/og/i/:guest", "destination": "/api/og?n=:guest" },
    { "source": "/", "destination": "/api/invite" },
    { "source": "/index.html", "destination": "/api/invite" }
  ],
  "functions": {
    "api/invite.js": {
      "includeFiles": "api/invite-template.html"
    },
    "api/og.js": {
      "includeFiles": "assets/fonts/IBMPlexMono-Medium.ttf"
    }
  }
}
